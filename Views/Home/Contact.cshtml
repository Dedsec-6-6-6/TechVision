
@{
    ViewBag.Title = "Contact";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Us | TechVision IT Solutions</title>
    <style>
        :root {
            --primary: #0056b3;
            --secondary: #20c997;
            --dark: #1a1a1a;
            --light: #f8f9fa;
            --border: #ddd;
        }

        /* Flexbox Body to keep footer at bottom */
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            line-height: 1.6;
            color: #333;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navigation */
        nav {
            background: var(--dark);
            color: white;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

            nav .logo {
                font-size: 1.5rem;
                font-weight: bold;
                color: var(--secondary);
                text-decoration: none;
            }

            nav ul {
                list-style: none;
                display: flex;
                margin: 0;
            }

                nav ul li {
                    margin-left: 20px;
                }

                    nav ul li a {
                        color: white;
                        text-decoration: none;
                        font-weight: 500;
                    }

        /* Main Content Area */
        .main-content {
            flex: 1;
        }

        /* Contact Section */
        .contact-container {
            max-width: 1100px;
            margin: 50px auto;
            padding: 0 5%;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 50px;
        }

        .contact-form h2,
        .contact-info h2 {
            color: var(--primary);
            margin-bottom: 20px;
        }

        /* Form Styling */
        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 5px;
                font-weight: bold;
            }

            .form-group input,
            .form-group textarea,
            .form-group select {
                width: 100%;
                padding: 12px;
                border: 1px solid var(--border);
                border-radius: 5px;
                font-size: 1rem;
                box-sizing: border-box; /* Ensures padding doesn't break width */
            }

        .submit-btn {
            background: var(--primary);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1rem;
            transition: background 0.3s;
        }

            .submit-btn:hover {
                background: #004494;
            }

        /* Info Sidebar */
        .contact-info {
            background: var(--light);
            padding: 30px;
            border-radius: 10px;
            height: fit-content;
        }

        .info-item {
            margin-bottom: 25px;
        }

            .info-item h4 {
                margin: 0 0 5px 0;
                color: var(--primary);
            }

        /* Footer - Fixed and Structured */
        footer {
            background: var(--dark);
            color: white;
            text-align: center;
            padding: 20px 5%;
            margin-top: 50px;
        }

            footer p {
                margin: 5px 0;
                font-size: 0.9rem;
                opacity: 0.8;
            }


        .active {
            border-bottom: 2px solid var(--secondary);
            padding-bottom: 2px;
        }

        .login-btn {
            background: var(--primary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .login-btn:hover {
                background: #004494;
            }

        .register-btn {
            background: var(--secondary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .register-btn:hover {
                background: #17a589;
            }

        .pages li a:hover {
            color: var(--secondary);
        }
    </style>
</head>
<body>
    <nav>
        <div class="logo">TechVision</div>
        <ul class="pages">
            <li>@Html.ActionLink("Home", "Index")</li>
            <li>@Html.ActionLink("Service", "Service")</li>
            <li>@Html.ActionLink("About", "About")</li>
            <li class="active">@Html.ActionLink("Contact", "Contact")</li>
            <li class="login-btn">@Html.ActionLink("Sign In", "Sign_in")</li>
            <li class="register-btn">@Html.ActionLink("Sign Up", "Sign_up")</li>
        </ul>
    </nav>

    <main class="main-content">
        <div class="contact-container">
            <section class="contact-form">
                <h2>Send us a Message</h2>
                <form action="#">
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text"
                               id="name"
                               name="name"
                               placeholder="John Smith"
                               required />
                    </div>
                    <div class="form-group">
                        <label for="email">Work Email</label>
                        <input type="email"
                               id="email"
                               name="email"
                               placeholder="john@company.com"
                               required />
                    </div>
                    <div class="form-group">
                        <label for="service">Interested Service</label>
                        <select id="service" name="service">
                            <option value="managed-it">Managed IT Services</option>
                            <option value="cybersecurity">Cybersecurity</option>
                            <option value="cloud">Cloud Solutions</option>
                            <option value="other">Other Inquiry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">How can we help?</label>
                        <textarea id="message"
                                  name="message"
                                  rows="5"
                                  placeholder="Tell us about your project..."></textarea>
                    </div>
                    <button type="submit" class="submit-btn">Send Request</button>
                </form>
            </section>

            <aside class="contact-info">
                <h2>Contact Info</h2>
                <div class="info-item">
                    <h4>Our Office</h4>
                    <p>Sikka House<br />Lucknow, Uttar Pradesh, India</p>
                </div>
                <div class="info-item">
                    <h4>Phone</h4>
                    <p>+91 7238997301</p>
                </div>
                <div class="info-item">
                    <h4>Email</h4>
                    <p>support@techvision.com</p>
                </div>
                <div class="info-item">
                    <h4>Support Hours</h4>
                    <p>Monday - Friday: 8am - 6pm<br />Emergency Support: 24/7</p>
                </div>
            </aside>
        </div>
    </main>

    <footer>
        <p>&copy; 2025 TechVision IT Solutions. All rights reserved.</p>
    </footer>
</body>
</html>



