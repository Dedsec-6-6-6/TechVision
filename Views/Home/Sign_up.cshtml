
@{
    ViewBag.Title = "Sign_up";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account | TechVision</title>
    <style>
        :root {
            --primary: #0056b3;
            --secondary: #20c997;
            --dark: #1a1a1a;
            --light: #f8f9fa;
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            line-height: 1.6;
            color: #333;
            background-color: #f4f7f6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navigation */
        nav {
            background: var(--dark);
            color: white;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

            nav .logo {
                font-size: 1.5rem;
                font-weight: bold;
                color: var(--secondary);
            }

            nav ul {
                list-style: none;
                display: flex;
                margin: 0;
            }

                nav ul li {
                    margin-left: 20px;
                }

                    nav ul li a {
                        color: white;
                        text-decoration: none;
                        font-weight: 500;
                    }

        .login-btn {
            background: var(--primary);
            padding: 8px 15px;
            border-radius: 5px;
        }

        .register-btn {
            background: var(--secondary);
            padding: 8px 15px;
            border-radius: 5px;
        }

        /* Container */
        .signup-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 5%;
        }

        .signup-card {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: var(--shadow);
            width: 100%;
            max-width: 450px; /* Slightly wider for the name fields */
        }

            .signup-card h2 {
                margin-top: 0;
                color: var(--dark);
                text-align: center;
                margin-bottom: 0.5rem;
            }

            .signup-card p.subtitle {
                text-align: center;
                color: #666;
                margin-bottom: 2rem;
                font-size: 0.9rem;
            }

        /* Form Elements */
        .form-row {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
            flex: 1;
        }

            .form-group label {
                display: block;
                margin-bottom: 5px;
                font-weight: 600;
                font-size: 0.9rem;
            }

            .form-group input {
                width: 100%;
                padding: 12px;
                border: 1px solid #ddd;
                border-radius: 5px;
                box-sizing: border-box;
            }

                .form-group input:focus {
                    outline: none;
                    border-color: var(--secondary);
                    box-shadow: 0 0 5px rgba(32, 201, 151, 0.2);
                }

        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 25px;
            font-size: 0.85rem;
        }

            .checkbox-group input {
                margin-top: 4px;
            }

        .submit-btn {
            width: 100%;
            background: var(--secondary);
            color: white;
            padding: 12px;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, background 0.3s;
        }

            .submit-btn:hover {
                background: #17a589;
                transform: translateY(-2px);
            }

        .form-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 0.9rem;
        }

            .form-footer a {
                color: var(--primary);
                text-decoration: none;
                font-weight: 600;
            }

        /* Footer */
        footer {
            background: var(--dark);
            color: white;
            text-align: center;
            padding: 20px 5%;
        }

            footer p {
                margin: 5px 0;
                font-size: 0.9rem;
                opacity: 0.8;
            }

        .login-btn {
            background: var(--primary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .login-btn:hover {
                background: #004494;
            }

        .register-btn {
            background: var(--secondary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .register-btn:hover {
                background: #17a589;
            }

        .pages li a:hover {
            color: var(--secondary);
        }
    </style>
</head>
<body>
    <nav>
        <div class="logo">TechVision</div>
        <ul class="pages">
            <li>@Html.ActionLink("Home", "Index")</li>
            <li>@Html.ActionLink("Service", "Service")</li>
            <li>@Html.ActionLink("About", "About")</li>
            <li>@Html.ActionLink("Contact", "Contact")</li>
            <li class="login-btn">@Html.ActionLink("Sign In", "Sign_in")</li>
            <li class="register-btn">@Html.ActionLink("Sign Up", "Sign_up")</li>
        </ul>
    </nav>

    <main class="signup-container">
        <div class="signup-card">
            <h2>Join TechVision</h2>
            <p class="subtitle">
                Start your journey with our premium IT solutions.
            </p>
            @if (TempData["Success"] != null)
            {
                <script>
                    alert("🎉 Account created successfully! Please login.");
                </script>
            }
            @if (ViewBag.Message != null)
            {
                <div style="background:#ffe0e0;color:#b30000;padding:10px;border-radius:5px;margin-bottom:15px;">
                    @ViewBag.Message
                </div>
            }


            <form method="post"
                  action="@Url.Action("Sign_up", "Home")"
                  onsubmit="return validateForm()">
                <div class="form-row">
                    <div class="form-group">
                        <label for="first-name">First Name</label>
                        <input type="text" id="first-name" name="FirstName" placeholder="John" required />
                    </div>
                    <div class="form-group">
                        <label for="last-name">Last Name</label>
                        <input type="text" id="last-name" name="LastName" placeholder="Smith" required />
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Work Email</label>
                    <input type="email"
                           id="email" name="Email"
                           placeholder="john.smith@company.com"
                           required />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password"
                           id="password"
                           name="Password"
                           placeholder="At least 8 characters"
                           minlength="8"
                           required />
                </div>

                <div class="form-group">
                    <label for="confirm_password">Confirm Password</label>
                    <input type="password"
                           id="confirm_password"
                           name="Confirm_Password"
                           minlength="8"
                           required />
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="terms" required />
                    <label for="terms">
                        I agree to the <a href="#">Terms of Service</a> and
                        <a href="#">Privacy Policy</a>.
                    </label>
                </div>

                <button type="submit" class="submit-btn">Create Free Account</button>
            </form>

            <div class="form-footer">
                <p>Already have an account? <a href="@Url.Action("Sign_In", "Home")">Sign In</a></p>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2025 TechVision IT Solutions. All rights reserved.</p>
    </footer>
    <script>
        function validateForm() {

            var password = document.getElementById("password").value;
            var confirm = document.getElementById("confirm_password").value;

            // password match check
            if (password !== confirm) {
                alert("❌ Passwords do not match!");
                return false;
            }

            // strong password check
            var strongPattern = /^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{8,}$/;

            if (!strongPattern.test(password)) {
                alert("⚠ Password must be at least 8 characters and include letters and numbers");
                return false;
            }

            return true;
        }
    </script>

</body>
</html>


