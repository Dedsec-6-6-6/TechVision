@{
    ViewBag.Title = "Forgot Password";
}
<title>Forgot Password</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<style>
    body {
        background: linear-gradient(135deg, #e3f2fd, #ffffff);
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border: none;
        border-radius: 15px;
    }

    .btn-primary, .btn-success {
        border-radius: 25px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    input.form-control {
        border-radius: 10px;
        padding: 10px;
    }
</style>

<div class="bg-light d-flex align-items-center justify-content-center" style="height:100vh;">
    <div class="card shadow-lg p-4 rounded-4" style="width:400px;">
        <h3 class="text-center mb-3 text-primary">Forgot Password</h3>
        <p class="text-center text-muted">Enter your registered email to reset your password</p>

        @using (Html.BeginForm("ForgotPassword", "Home", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                @Html.TextBox("Email", null, new { @class = "form-control", placeholder = "Enter your email" })
            </div>

            <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
        }

        <div class="mt-3 text-center text-success">
            @ViewBag.Message
        </div>
        <div class="text-center text-danger">
            @ViewBag.Error
        </div>

        <div class="text-center mt-3">
            <a href="@Url.Action("Sign_in","Home")">Back to Login</a>
        </div>
    </div>
</div>