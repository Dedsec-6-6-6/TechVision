@model IEnumerable<TechVision.Models.UserViewModel>

@{
    ViewBag.Title = "Admin Panel";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Panel | TechVision</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 240px;
            height: 100vh;
            background: #1e293b;
            color: white;
            position: fixed;
            padding-top: 20px;
        }

            .sidebar h2 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                padding: 12px 20px;
                color: #cbd5e1;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #334155;
                    color: white;
                }

        /* ===== MAIN CONTENT ===== */
        .main {
            margin-left: 240px;
            padding: 30px;
        }

        .header {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 25px;
        }

        /* ===== CARDS ===== */
        .cards {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            flex: 1;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        }

            .card h3 {
                margin: 0;
                font-size: 20px;
                color: #333;
            }

            .card p {
                font-size: 28px;
                margin: 10px 0 0;
                font-weight: bold;
                color: #4e73df;
            }

        /* ===== TABLE ===== */
        table {
            width: 100%;
            background: white;
            border-collapse: collapse;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        }

        th {
            background: #4e73df;
            color: white;
            padding: 14px;
            text-align: left;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }

        tr:hover {
            background: #f1f5ff;
        }

        .btn-delete {
            padding: 6px 12px;
            background: #e74a3b;
            color: white;
            border-radius: 6px;
            text-decoration: none;
            font-size: 13px;
        }

            .btn-delete:hover {
                background: #c0392b;
            }

        .btn-edit {
            padding: 6px 12px;
            background: #1cc88a;
            color: white;
            border-radius: 6px;
            text-decoration: none;
            font-size: 13px;
        }

            .btn-edit:hover {
                background: #17a673;
            }

        .btn-print {
            padding: 6px 12px;
            background: #36b9cc;
            color: white;
            border-radius: 6px;
            text-decoration: none;
            font-size: 13px;
        }

            .btn-print:hover {
                background: #2c9faf;
            }

    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h2><i class="fa-solid fa-shield-halved"></i> Admin</h2>

        <a href="#"><i class="fa-solid fa-users"></i> Manage Users</a>
        <a href="#"><i class="fa-solid fa-chart-line"></i> Reports</a>
        <a href="@Url.Action("Dashboard","Home")">
            <i class="fa-solid fa-user"></i> User Dashboard
        </a>
        <a href="@Url.Action("Logout","Home")">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main">

        <div class="header">
            Admin Dashboard
        </div>

        <!-- Cards -->
        <div class="cards">
            <div class="card">
                <h3>Total Users</h3>
                <p>@Model.Count()</p>
            </div>

            <div class="card">
                <h3>Active Users</h3>
                <p>@Model.Count()</p>
            </div>
        </div>

        <!-- Users Table -->
        <table>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Address</th>
                <th>DOB</th>
                <th>Action</th>
            </tr>

            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Address</td>
                    <td>@user.DOB</td>
                    <td style="display:flex; gap:8px;">

                        <!-- Edit -->
                        <a href="@Url.Action("EditUser","Home", new { id = user.Id })"
                           class="btn-edit">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>

                        <!-- Delete -->
                        <a href="@Url.Action("DeleteUser","Home", new { id = user.Id })"
                           class="btn-delete"
                           onclick="return confirm('Delete this user?');">
                            <i class="fa-solid fa-trash"></i> Delete
                        </a>

                        <!-- Print -->
                        <a href="@Url.Action("PrintUser", "Home", new { id = user.Id })" target="_blank">
                            Print
                        </a>


                    </td>

                </tr>
            }
        </table>

    </div>

</body>
</html>
