@{
    ViewBag.Title = "Admin Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard | TechVision</title>

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
        }

        /* ===== HEADER ===== */
        .header {
            background: linear-gradient(135deg, #4e73df, #1cc88a);
            color: white;
            padding: 30px;
            text-align: center;
        }

            .header h1 {
                margin: 0;
                font-size: 28px;
            }

            .header p {
                margin-top: 8px;
                opacity: 0.9;
            }

        /* ===== MAIN CONTAINER ===== */
        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 20px;
        }

        /* ===== CARDS ===== */
        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            transition: 0.3s;
            text-align: center;
        }

            .card:hover {
                transform: translateY(-5px);
            }

            .card i {
                font-size: 40px;
                margin-bottom: 15px;
                color: #4e73df;
            }

            .card h3 {
                margin: 10px 0;
                color: #333;
            }

            .card p {
                color: #777;
                font-size: 14px;
            }

        .btn {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .btn-primary {
            background: #4e73df;
            color: white;
        }

            .btn-primary:hover {
                background: #2e59d9;
            }

        .btn-secondary {
            background: #858796;
            color: white;
        }

            .btn-secondary:hover {
                background: #6c757d;
            }
    </style>
</head>

<body>

    <!-- Header -->
    <div class="header">
        <h1><i class="fa-solid fa-shield-halved"></i> Admin Dashboard</h1>
        <p>Manage your TechVision system efficiently</p>
    </div>

    <!-- Content -->
    <div class="container">
        <div class="cards">

            <!-- Manage Users -->
            <div class="card">
                <i class="fa-solid fa-users"></i>
                <h3>Manage Users</h3>
                <p>View, manage and control registered users.</p>
                <a href="@Url.Action("ManageUsers","Home")" class="btn btn-primary">
                    Open
                </a>
            </div>

            <!-- User Dashboard -->
            <div class="card">
                <i class="fa-solid fa-user"></i>
                <h3>User Dashboard</h3>
                <p>Switch back to the normal user panel.</p>
                <a href="@Url.Action("Dashboard","Home")" class="btn btn-secondary">
                    Go to Dashboard
                </a>
            </div>

        </div>
    </div>

</body>
</html>
