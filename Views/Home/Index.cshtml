
@{
    ViewBag.Title = "Index";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechVision | Managed IT Services & Solutions</title>
    <style>
        :root {
            --primary: #0056b3;
            --secondary: #20c997;
            --dark: #1a1a1a;
            --light: #f8f9fa;
        }

        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            line-height: 1.6;
            color: #333;
        }

        nav {
            background: var(--dark);
            color: white;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

            nav .logo {
                font-size: 1.5rem;
                font-weight: bold;
                color: var(--secondary);
            }

            nav ul {
                list-style: none;
                display: flex;
                margin: 0;
            }

                nav ul li {
                    margin-left: 20px;
                }

                    nav ul li a {
                        color: white;
                        text-decoration: none;
                        font-weight: 500;
                    }

        .active {
            border-bottom: 2px solid var(--secondary);
            padding-bottom: 2px;
        }

        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url("https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1350&q=80");
            background-size: cover;
            color: white;
            padding: 100px 5%;
            text-align: center;
        }

            .hero h1 {
                font-size: 3rem;
                margin-bottom: 1rem;
            }

        .btn {
            background: white;
            color: var(--dark);
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            display: inline-block;
            margin-top: 20px;
        }

            .btn:hover {
                background: #e9ecef;
                box-shadow: 0px 1px 15px rgb(255, 255, 255);
            }

        .services {
            padding: 50px 5%;
            background: var(--light);
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .card {
            background: var(--light);
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.137);
            text-align: center;
        }

            .card:hover {
                box-shadow: 0 8px 12px rgb(0, 0, 0);
                transform: translateY(-5px);
                transition: all 0.3s ease;
            }

            .card h3 {
                color: var(--primary);
            }

        footer {
            background: var(--dark);
            color: white;
            text-align: center;
            padding: 20px 5%;
            margin-top: 50px;
        }

            footer p {
                margin: 5px 0;
                font-size: 0.9rem;
                opacity: 0.8;
            }

        .login-btn {
            background: var(--primary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .login-btn:hover {
                background: #004494;
            }

        .register-btn {
            background: var(--secondary);
            padding: 8px 15px;
            border-radius: 5px;
        }

            .register-btn:hover {
                background: #17a589;
            }

        .pages li a:hover {
            color: var(--secondary);
        }
    </style>
</head>
<body>
    <nav>
        <div class="logo">TechVision</div>
        <ul class="pages">
            <li class="active">@Html.ActionLink("Home", "Index")</li>
            <li>@Html.ActionLink("Service", "Service")</li>
            <li>@Html.ActionLink("About", "About")</li>
            <li>@Html.ActionLink("Contact", "Contact")</li>
            <li class="login-btn">@Html.ActionLink("Sign In", "Sign_in")</li>
            <li class="register-btn">@Html.ActionLink("Sign Up", "Sign_up")</li>
        </ul>
    </nav>

    <header class="hero" id="home">
        <h1>Empowering Your Business Through Technology</h1>
        <p>From Cloud Computing to Cybersecurity—we've got you covered.</p>
        <br />
    </header>

    <section class="services" id="services">
        <h2 style="text-align: center">Our Expertise</h2>
        <div class="services-grid">
            <div class="card">
                <h3>Cloud Solutions</h3>
                <p>
                    Migrate your infrastructure to the cloud with seamless AWS and Azure
                    integration.
                </p>
            </div>
            <div class="card">
                <h3>Cybersecurity</h3>
                <p>
                    Protect your data with advanced threat detection and 24/7
                    monitoring.
                </p>
            </div>
            <div class="card">
                <h3>Managed IT</h3>
                <p>
                    Focus on your business while we handle your hardware, software, and
                    networks.
                </p>
            </div>
        </div>
    </section>

    <footer>
        <p>&copy; 2025 TechVision IT Solutions. All rights reserved.</p>
    </footer>
</body>
</html>

